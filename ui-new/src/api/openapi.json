    "/data/capability": {
      "get": {
        "tags": [],
        "operationId": "get_capability_history_doc",
        "parameters": [
          {
            "name": "entityId",
            "in": "query",
            "description": "Entity id with capability suffix",
            "required": true,
            "schema": {
              "type": "string"
