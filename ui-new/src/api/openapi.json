  "components": {
    "schemas": {
      "ApiServerConfigDoc": {
        "type": "object",
        "required": [
          "basicAuth",
          "oidcConfigured"
        ],
        "properties": {
          "basicAuth": {
            "type": "boolean"
          },
          "oidcConfig": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/OidcConfigDoc"
              }
            ]
          },
          "oidcConfigured": {
            "type": "boolean"
          }
        }
      },
      "CapabilityHistoryDoc": {
        "type": "object",
        "required": [
          "eventType",
          "eventTime",
          "dataName",
          "dataValue",
          "entityId"
        ],
        "properties": {
          "dataName": {
            "type": "string"
          },
          "dataValue": {
            "type": "string"
          },
          "entityId": {
            "type": "string"
          },
          "eventTime": {
            "type": "string"
          },
          "eventType": {
            "type": "string"
          }
        }
      },
      "EmailSettingsDoc": {
        "type": "object",
        "required": [
          "server_address",
          "server_port_number",
          "email_username",
          "email_password",
          "recipient_list",
          "notifications_device_unreachable",
          "notification_device_low_battery"
        ],
        "properties": {
          "email_password": {
            "type": "string"
          },
          "email_username": {
            "type": "string"
          },
          "notification_device_low_battery": {
            "type": "boolean"
          },
          "notifications_device_unreachable": {
            "type": "boolean"
          },
          "recipient_list": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "server_address": {
            "type": "string"
          },
          "server_port_number": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "EmailTestDoc": {
        "type": "object",
        "required": [
          "result"
        ],
        "properties": {
          "result": {
            "type": "string"
          }
        }
      },
      "HashDoc": {
        "type": "object",
        "required": [
          "hash"
        ],
        "properties": {
          "hash": {
            "type": "string"
          }
        }
      },
      "LocationDoc": {
        "type": "object",
        "required": [
          "id",
          "config"
        ],
        "properties": {
          "config": {},
          "devices": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "string"
            }
          },
          "id": {
            "type": "string"
          },
          "tags": {}
        }
      },
      "OidcConfigDoc": {
        "type": "object",
        "required": [
          "authority",
          "clientId",
          "redirectUri",
          "scope"
        ],
        "properties": {
          "authority": {
            "type": "string"
          },
          "clientId": {
            "type": "string"
          },
          "redirectUri": {
            "type": "string"
          },
          "scope": {
            "type": "string"
          }
        }
      },
      "ProductDoc": {
        "type": "object",
        "required": [
          "id",
          "type"
        ],
        "properties": {
          "config": {},
          "generic": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "id": {
            "type": "string"
          },
          "provisioned": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "state": {},
          "type": {
            "type": "string"
          },
          "version": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "SunTimesDoc": {
        "type": "object",
        "required": [
          "geoLocation",
          "latitude",
          "longitude"
        ],
        "properties": {
          "geoLocation": {
            "type": "string"
          },
          "latitude": {
            "type": "number",
            "format": "double"
          },
          "longitude": {
            "type": "number",
            "format": "double"
          },
          "nextEventAt": {
            "type": [
              "string",
              "null"
            ]
          },
          "nextEventName": {
            "type": [
              "string",
              "null"
            ]
          },
          "nextSunrise": {
            "type": [
              "string",
              "null"
            ]
          },
          "nextSunset": {
            "type": [
              "string",
              "null"
            ]
          },
          "sunrise": {
            "type": [
              "string",
              "null"
            ]
          },
          "sunset": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "UsbStorageDoc": {
        "type": "object",
        "required": [
          "external_storage"
        ],
        "properties": {
          "external_storage": {
            "type": "boolean"
          }
        }
      }
    }
  },
