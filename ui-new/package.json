{
  "name": "ui-new",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest --browser.enabled --run",
    "test:browser": "vitest --browser.enabled --run",
    "msw:init": "msw init public --save",
    "lint": "eslint src --ext ts,tsx --max-warnings 0",
    "generate:schema": "openapi-typescript src/api/openapi.json -o src/api/schema.d.ts",
    "generate:openapi": "cargo run --manifest-path ../api/Cargo.toml --bin export_openapi > src/api/openapi.json && pnpm run generate:schema",
    "preview": "vite preview",
    "build:copy": "pnpm run build --emptyOutDir --out-dir ../api/static"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toast": "^1.2.19",
    "@tanstack/react-query": "^5.101.2",
    "apexcharts": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.25.0",
    "oidc-client-ts": "^3.5.0",
    "openapi-fetch": "^0.17.0",
    "openapi-react-query": "^0.5.4",
    "react": "^19.2.7",
    "react-apexcharts": "^2.1.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-i18next": "^17.0.10",
    "react-oidc-context": "^3.3.1",
    "react-router": "^8.2.0",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vite-plugin-svgr": "^5.2.0",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@vitest/browser": "^4.1.10",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "msw": "^2.15.0",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.61.1",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}